# App URL path prefix for production builds (must start with / for subfolders).
# Examples:
#   Vercel / Netlify at domain root → leave empty or use /
#   GitHub Pages at https://user.github.io/repo-name/ → VITE_BASE_URL=/repo-name/
#
VITE_BASE_URL=

# Admin-only access to the offer letter generator (/). Document verification (/verify/*) stays public.
# These values are embedded in the client bundle at build time — use strong passwords and restrict hosting access.
VITE_ADMIN_USERNAME=
VITE_ADMIN_PASSWORD=

# Local development only: skip the login screen (never enable in production).
# VITE_AUTH_DISABLED=true
 